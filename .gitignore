# Eclipse workspace metadata
.metadata/

# OS / editor junk
.DS_Store
Thumbs.db

# Common generated files
**/bin/
**/tmp/
**/temp/

# Java compiled classes
**/*.class

# VS Code:共用設定(.vscode/settings.json、extensions.json、*.code-workspace)
# 「要」進 git 與 Eclipse 設定一起共用,故不在此忽略;
# 只忽略 jdt.ls(VS Code 的 Java 語言伺服器)會自動產生的暫存。
.factorypath
**/.vscode/*.log